# .env Example - Copy to .env and fill in your own keys

# ========================================
# API KEYS (Required for Production)
# ========================================

# EIA API Key - https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_key_here

# EPA API Key - https://www.epa.gov/developers/using-epa-data
EPA_API_KEY=your_epa_key_here

# Groq API Key - https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# FireCrawl API Key - https://www.firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Nunchuk API Key - https://nunchuk.io/developers
NUNCHUK_API_KEY=your_nunchuk_key_here

# ========================================
# Server Configuration
# ========================================

PORT=3001
NODE_ENV=development
VITE_API_URL=http://localhost:3001

# ========================================
# Nostr Configuration
# ========================================

# Public relays (no key needed)
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# ========================================
# Lightning Network (Optional - for real payments)
# ========================================

LNBITS_URL=https://lnbits.com
LNBITS_WALLET_KEY=your_lnbits_wallet_key_here

# ========================================
# Database (Optional - for production)
# ========================================

# DATABASE_URL=mongodb://localhost:27017/veridion-x
# DB_HOST=localhost
# DB_PORT=27017
# DB_NAME=veridion-x
